{
    "name": "gas",
    "version": "1.0.0",
    "description": "GAS TypeScript + Webpack Starter",
    "main": "index.js",
    "scripts": {
        "build": "(npm run build:backend & npm run build:frontend) && npm run copy:frontend",
        "build:backend": "webpack",
        "build:frontend": "cd frontend && npm run build",
        "copy:frontend": "node copy-frontend.js",
        "build:watch": "webpack --watch",
        "test": "jest",
        "test:watch": "jest --watch",
        "lint": "oxlint src --tsconfig tsconfig.json",
        "lint:fix": "oxlint src --tsconfig tsconfig.json --fix",
        "format": "oxfmt --config .oxfmtrc.json --write src package.json tsconfig.json appsscript.json webpack.config.js jest.config.js copy-frontend.js .oxfmtrc.json",
        "format:check": "oxfmt --config .oxfmtrc.json --check src package.json tsconfig.json appsscript.json webpack.config.js jest.config.js copy-frontend.js .oxfmtrc.json",
        "push": "npm run build && npx clasp push",
        "open": "npx clasp open-script"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "devDependencies": {
        "@google/clasp": "^3.1.3",
        "@types/google-apps-script": "^2.0.8",
        "@types/jest": "^30.0.0",
        "clean-webpack-plugin": "^4.0.0",
        "copy-webpack-plugin": "^14.0.0",
        "gas-webpack-plugin": "^2.6.0",
        "jest": "^30.2.0",
        "oxfmt": "^0.45.0",
        "oxlint": "^1.60.0",
        "ts-jest": "^29.4.6",
        "ts-loader": "^9.5.4",
        "typescript": "^5.9.3",
        "webpack": "^5.103.0",
        "webpack-cli": "^6.0.1"
    }
}
